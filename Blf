		TweenService:Create(FAKnob, tweenInfo, { Position = UDim2.new(0, 2, 0, 2) }):Play()
		TweenService:Create(FAKnob, tweenInfoColor, { BackgroundColor3 = COLOR_OFF_KNOB }):Play()
