--[[
    ===================================================================
    SCRIPT HUB UI - THEME XANH DƯƠNG (BLUE THEME)
    ===================================================================
    Cấu trúc UI hiện tại:
    1. Viền glow chạy quanh UI (StrokeGradient xanh dương)
    2. Nền UI xanh navy, trong suốt 30% (không Blur phía sau UI)
    3. 2 nút Toggle Bật/Tắt:
         - "Freeze Trade"
         - "Force Accept"
    4. Font chữ: Michroma (phong cách công nghệ/sci-fi, hợp với
       theme glow xanh dương của UI)
    5. Kéo thả để di chuyển UI (Drag)
    ===================================================================
]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")

local player = Players.LocalPlayer
local guiContainer = game:GetService("CoreGui") or player:WaitForChild("PlayerGui")

-- Dọn UI cũ (nếu có) trước khi tạo UI mới, tránh bị trùng lặp
if guiContainer:FindFirstChild("OptimizedGradientUI") then
    guiContainer.OptimizedGradientUI:Destroy()
end
-- Dọn luôn BlurEffect của bản cũ (nếu trước đó từng tạo) -> bản hiện tại không dùng Blur
if Lighting:FindFirstChild("UIBlurEffect") then
    Lighting.UIBlurEffect:Destroy()
end

--[[ ============== BẢNG MÀU XANH DƯƠNG DÙNG CHUNG ==============
     Khai báo riêng thành biến để sau này muốn đổi tông màu chỉ cần
     sửa ở đây, không cần tìm rải rác trong code.
]]
local COLOR_NAVY_BG     = Color3.fromRGB(8, 14, 28)     -- nền chính UI (xanh navy rất tối)
local COLOR_NEON_BLUE   = Color3.fromRGB(0, 170, 255)   -- xanh dương sáng (glow, highlight, nhấn)
local COLOR_MID_BLUE    = Color3.fromRGB(45, 120, 220)  -- xanh dương trung bình (giữa gradient toggle)
local COLOR_DARK_BLUE   = Color3.fromRGB(15, 35, 70)    -- xanh dương đậm (2 đầu gradient toggle)
local COLOR_TRACK_BG    = Color3.fromRGB(8, 14, 28)     -- nền track toggle (đồng bộ với nền UI)

-- Font dùng cho toàn bộ UI -> Michroma: font công nghệ/sci-fi, hợp với theme glow xanh dương
local UI_FONT = Enum.Font.Michroma

-- ========================= MAIN FRAME =========================
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "OptimizedGradientUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.IgnoreGuiInset = true
ScreenGui.Parent = guiContainer

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 320, 0, 200)        -- thu nhỏ lại cho vừa 2 toggle (bớt khoảng trống thừa)
MainFrame.Position = UDim2.new(0.5, -160, 0.5, -100)
MainFrame.BackgroundColor3 = COLOR_NAVY_BG
MainFrame.BackgroundTransparency = 0.3
MainFrame.BorderSizePixel = 0
MainFrame.Parent = ScreenGui

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 12)
UICorner.Parent = MainFrame

-- Viền ngoài UI
local UIStroke = Instance.new("UIStroke")
UIStroke.Thickness = 2.5
UIStroke.Color = Color3.fromRGB(255, 255, 255)
UIStroke.Transparency = 0.1
UIStroke.Parent = MainFrame

-- Gradient cho viền (đây chính là dải "glow" chạy vòng quanh UI)
local StrokeGradient = Instance.new("UIGradient")
StrokeGradient.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0,   COLOR_NAVY_BG),
    ColorSequenceKeypoint.new(0.4, COLOR_NAVY_BG),
    ColorSequenceKeypoint.new(0.5, COLOR_NEON_BLUE),
    ColorSequenceKeypoint.new(0.6, COLOR_NAVY_BG),
    ColorSequenceKeypoint.new(1,   COLOR_NAVY_BG)
}
StrokeGradient.Parent = UIStroke

-- Vòng lặp xoay gradient viền liên tục -> tạo hiệu ứng glow chạy vòng quanh UI
RunService.RenderStepped:Connect(function(deltaTime)
    StrokeGradient.Rotation = (StrokeGradient.Rotation + 120 * deltaTime) % 360
end)

local UIListLayout = Instance.new("UIListLayout")
UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
UIListLayout.Padding = UDim.new(0, 15)
UIListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
UIListLayout.Parent = MainFrame

local UIPadding = Instance.new("UIPadding")
UIPadding.PaddingTop = UDim.new(0, 20)
UIPadding.PaddingBottom = UDim.new(0, 20)
UIPadding.Parent = MainFrame

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(0.9, 0, 0, 30)
Title.BackgroundTransparency = 1
Title.Text = "Trade Scam Panel"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextScaled = true
Title.Font = UI_FONT
Title.Parent = MainFrame

-- ===================== HÀM TẠO GRADIENT CHÉO =====================
-- Dùng cho nền của các nút Toggle -> tông xanh dương (đậm -> trung bình -> đậm), chéo 15 độ
local function applyDiagonalGradient(parent)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0,   COLOR_DARK_BLUE),
        ColorSequenceKeypoint.new(0.5, COLOR_MID_BLUE),
        ColorSequenceKeypoint.new(1,   COLOR_DARK_BLUE)
    }
    gradient.Rotation = 15
    gradient.Parent = parent
    return gradient
end

-- ===================== HÀM TẠO 1 NÚT TOGGLE (TÁI SỬ DỤNG) =====================
-- Vì UI có nhiều toggle giống nhau (Freeze Trade, Force Accept...), tách ra 1 hàm
-- để không phải lặp code -> sau này thêm toggle mới chỉ cần gọi lại hàm này.
-- Trả về: Container (Frame) và hàm getState() để đọc trạng thái Bật/Tắt hiện tại.
local function createToggle(labelText, layoutOrder)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(0.85, 0, 0, 45)
    Container.BackgroundColor3 = COLOR_NEON_BLUE
    Container.LayoutOrder = layoutOrder
    Container.Parent = MainFrame

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 8)
    Corner.Parent = Container

    applyDiagonalGradient(Container)

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.7, 0, 1, 0)
    Label.Position = UDim2.new(0, 10, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = labelText
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.Font = UI_FONT
    Label.TextSize = 16
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Container

    local Track = Instance.new("Frame")
    Track.Size = UDim2.new(0, 40, 0, 20)
    Track.Position = UDim2.new(1, -50, 0.5, -10)
    Track.BackgroundColor3 = COLOR_TRACK_BG
    Track.Parent = Container

    local TrackCorner = Instance.new("UICorner")
    TrackCorner.CornerRadius = UDim.new(1, 0)
    TrackCorner.Parent = Track

    local Knob = Instance.new("Frame")
    Knob.Size = UDim2.new(0, 16, 0, 16)
    Knob.Position = UDim2.new(0, 2, 0.5, -8)
    Knob.BackgroundColor3 = Color3.fromRGB(180, 200, 220)
    Knob.Parent = Track

    local KnobCorner = Instance.new("UICorner")
    KnobCorner.CornerRadius = UDim.new(1, 0)
    KnobCorner.Parent = Knob

    local ClickButton = Instance.new("TextButton")
    ClickButton.Size = UDim2.new(1, 0, 1, 0)
    ClickButton.BackgroundTransparency = 1
    ClickButton.Text = ""
    ClickButton.Parent = Container

    -- Logic bật/tắt -> khi BẬT, track sáng lên xanh neon, núm chuyển xanh navy đậm
    local isOn = false
    ClickButton.MouseButton1Click:Connect(function()
        isOn = not isOn
        if isOn then
            TweenService:Create(Track, TweenInfo.new(0.3), {BackgroundColor3 = COLOR_NEON_BLUE}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.3), {Position = UDim2.new(1, -18, 0.5, -8), BackgroundColor3 = COLOR_NAVY_BG}):Play()
        else
            TweenService:Create(Track, TweenInfo.new(0.3), {BackgroundColor3 = COLOR_TRACK_BG}):Play()
            TweenService:Create(Knob, TweenInfo.new(0.3), {Position = UDim2.new(0, 2, 0.5, -8), BackgroundColor3 = Color3.fromRGB(180, 200, 220)}):Play()
        end

        -- ============ GẮN CHỨC NĂNG THỰC TẾ CỦA TOGGLE TẠI ĐÂY ============
        -- "isOn" = true/false là trạng thái mới nhất ngay sau khi bấm.
        -- Ví dụ: if labelText == "Freeze Trade" then ... end
    end)

    return Container, function() return isOn end
end

-- ============================ TOGGLE: FREEZE TRADE ============================
local FreezeTradeContainer, getFreezeTradeState = createToggle("Freeze Trade", 1)

-- ============================ TOGGLE: FORCE ACCEPT ============================
local ForceAcceptContainer, getForceAcceptState = createToggle("Force Accept", 2)

-- ===================== KÉO THẢ DI CHUYỂN UI (DRAG) =====================
local dragToggle = false
local dragStart, startPos

MainFrame.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragToggle = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        TweenService:Create(MainFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = newPos}):Play()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragToggle = false
    end
end)
