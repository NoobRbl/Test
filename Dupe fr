btn.MouseButton1Click:Connect(function()
    local char = player.Character
    if not char then
        status.Text = "Character not found"
        status.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then
        status.Text = "No fruit equipped"
        status.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    tool.Archivable = true
    local clone = tool:Clone()
    clone.Parent = player.Backpack

    status.Text = "Duped: " .. tool.Name
    status.TextColor3 = Color3.fromRGB(120, 220, 160)

    task.delay(2, function()
        status.Text = ""
    end)
end)

-- ═══════════════════════════════════════
--   DRAG LOGIC  –  RunService (mượt)
-- ═══════════════════════════════════════

local dragging    = false
local dragOffsetX = 0
local dragOffsetY = 0
local dragConn    = nil

top.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then

        dragging = true

        -- Tính offset giữa góc trái-trên của main và vị trí chuột
        local absPos = main.AbsolutePosition
        dragOffsetX = input.Position.X - absPos.X
        dragOffsetY = input.Position.Y - absPos.Y

        -- Kết nối RenderStepped để cập nhật mỗi frame → mượt nhất
        dragConn = RunService.RenderStepped:Connect(function()
            if not dragging then
                dragConn:Disconnect()
                dragConn = nil
                return
            end
            local mousePos = UIS:GetMouseLocation()
            main.Position = UDim2.new(
                0, mousePos.X - dragOffsetX,
                0, mousePos.Y - dragOffsetY
            )
        end)
    end
end)

top.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
